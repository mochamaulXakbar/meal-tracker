              "path": ["berat"]
            },
            "description": "Data mentah semua entri, urut baru ke lama."
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI Meal Planner",
      "item": [
        {
          "name": "Generate Menu",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/meal-plan/generate",
              "host": ["{{base_url}}"],
              "path": ["meal-plan", "generate"]
            },
            "description": "Tidak perlu body — TDEE dihitung otomatis dari profil. Hasil di-cache 5 menit per user, dan otomatis disimpan sebagai riwayat ke tabel rencana_menu."
          },
          "response": []
        },
        {
          "name": "Riwayat Menu",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/meal-plan/riwayat",
              "host": ["{{base_url}}"],
              "path": ["meal-plan", "riwayat"]
            },
            "description": "30 riwayat menu terakhir yang pernah di-generate, urut baru ke lama."
          },
          "response": []
        }
      ]
    },
